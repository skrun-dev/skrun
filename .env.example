# LLM Provider API Keys — set at least one
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=your-google-api-key-here
# MISTRAL_API_KEY=...
# GROQ_API_KEY=gsk_...
# XAI_API_KEY=xai-...

# Dashboard agent import — points at the demo agents directory.
# Path is resolved relative to the registry's working directory.
# `pnpm dev:registry` runs from `packages/api/` so the path needs to climb
# two levels back to the repo root. If you start the registry from the
# repo root directly, use `./agents` instead.
SKRUN_AGENTS_DIR=../../agents

# Multimodal inputs (#56) — uploaded input files via POST /api/files
# INPUT_FILES_MAX_SIZE_MB=25         # Max upload size per file (default 25 MB)
# INPUT_FILES_RETENTION_S=86400       # How long uploaded inputs persist (default 24 h)
# INPUT_FILES_MAX_INLINE_MB=4         # Max base64 inline size on POST /run (default 4 MB)
