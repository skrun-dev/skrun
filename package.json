{
  "name": "skrun",
  "private": true,
  "type": "module",
  "description": "Deploy any Agent Skill as an API — The Vercel for Agent Skills",
  "keywords": [
    "agent-skills",
    "ai-agents",
    "llm",
    "api",
    "runtime",
    "agent-as-api",
    "typescript",
    "hono",
    "multi-model",
    "stateful-agents"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "dev": "pnpm -r run dev",
    "dev:web": "pnpm --filter @skrun-dev/web dev",
    "build:web": "pnpm --filter @skrun-dev/web build",
    "dev:registry": "pnpm --filter @skrun-dev/api dev",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:e2e:live": "node --env-file=.env --import tsx tests/e2e.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "ffmpeg-static": "^5.3.0",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild", "ffmpeg-static"]
  }
}
