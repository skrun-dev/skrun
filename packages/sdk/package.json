{
  "name": "@skrun-dev/sdk",
  "version": "0.7.0",
  "description": "Official TypeScript SDK for calling Skrun agents",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skrun-dev/skrun.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/skrun-dev/skrun#readme",
  "bugs": "https://github.com/skrun-dev/skrun/issues",
  "keywords": [
    "skrun",
    "agent-skills",
    "ai-agents",
    "sdk",
    "llm"
  ],
  "engines": {
    "node": ">=22.0.0"
  }
}
